# Morning Briefing Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Get from https://openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-your-key-here

# Get from https://api.slack.com/apps → OAuth & Permissions → User OAuth Token
# Must start with xoxp- (User Token, not Bot Token)
SLACK_BOT_TOKEN=xoxp-your-token-here
